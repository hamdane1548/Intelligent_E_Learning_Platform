# Copier ce fichier vers .env et remplir les valeurs
# Clé secrète pour signer les tokens JWT (obligatoire en production)
SECRET_KEY=change_me_to_a_long_random_string

# Service IA (résumés et quiz). Par défaut : Ollama local.
# Pour OpenAI : AI_BASE_URL=https://api.openai.com/v1, AI_MODEL=gpt-4o-mini, AI_API_KEY=sk-...
AI_BASE_URL=http://localhost:11434/v1
AI_MODEL=llama3
AI_API_KEY=ollama
AI_TIMEOUT=120

# Modèle d'embedding pour l'assistant RAG (ollama pull nomic-embed-text)
EMBED_MODEL=nomic-embed-text
